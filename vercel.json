{
  "version": 2,
  "redirects": [
    { "source": "https://www.treenjohnportfolio.com/:path*", "destination": "https://treenjohnportfolio.com/:path*", "permanent": true }
  ],
  "headers": [
    { "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "routes": [
    { "src": "/(.*)\\.(js|css|svg|png|jpg|jpeg|webp|ico|json)$", "headers": { "cache-control": "public, max-age=31536000, immutable" }, "dest": "/$1.$2" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
